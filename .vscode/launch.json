{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Check Project Structure",
      "type": "python",
      "request": "launch",
      "module": "motorcycle_growth.cli",
      "args": ["check-project"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Show Project Paths",
      "type": "python",
      "request": "launch",
      "module": "motorcycle_growth.cli",
      "args": ["show-paths"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Pipeline Placeholder",
      "type": "python",
      "request": "launch",
      "module": "motorcycle_growth.pipeline",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Dashboard Placeholder",
      "type": "python",
      "request": "launch",
      "module": "motorcycle_growth.dashboard",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
